    "test:integration": "NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules npx jest tests/integration.test.js",
    "test:unit": "NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules npx jest tests/queue.test.js",
