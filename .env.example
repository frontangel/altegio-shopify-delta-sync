NODE_ENV=development

# Shopify
SF_DOMAIN=your-store.myshopify.com
SF_ADMIN_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SF_API_VERSION=2025-04
SF_CONST_LOCATION_ID=gid://shopify/Location/000000000000

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=           # порожнє, якщо без пароля
REDIS_URL=redis://localhost:6379

# Altegio (partner + user tokens with your partner cabinet)
ALTEGIO_TOKEN=your_altegio_partner_token
ALTEGIO_USER_TOKEN=your_altegio_user_token
ALTEGIO_STORAGE_ID=0000000
ALTEGIO_COMPANY_ID=0000000

# Basic Auth для адмін-роутів
BASIC_AUTH_USER=admin
BASIC_AUTH_PASS=change_me

# Process split (див. README): API без воркера/warmup, worker — окремий процес
QUEUE_WORKER_AUTOSTART=true
WARMUP_ON_START=true
